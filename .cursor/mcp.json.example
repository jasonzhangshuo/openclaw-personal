{
  "mcpServers": {
    "memos-api-mcp": {
      "timeout": 60,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@memtensor/memos-api-mcp@latest"
      ],
      "env": {
        "MEMOS_API_KEY": "<从 .env 或 MemOS 控制台复制>",
        "MEMOS_USER_ID": "<与 .env 中 MEMOS_USER_ID 一致>",
        "MEMOS_CHANNEL": "MODELSCOPE"
      }
    }
  }
}
